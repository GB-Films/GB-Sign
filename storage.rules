rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function email() { return request.auth.token.email.lower(); }
    function project(projectId) {
      return firestore.get(/databases/(default)/documents/projects/$(projectId));
    }
    function document(projectId, docId) {
      return firestore.get(/databases/(default)/documents/projects/$(projectId)/documents/$(docId));
    }
    function isOwner(projectId) {
      return signedIn() && project(projectId).data.ownerUid == request.auth.uid;
    }
    function isCollaborator(projectId) {
      return signedIn()
        && project(projectId).data.collaboratorEmails is list
        && email() in project(projectId).data.collaboratorEmails;
    }
    function isProjectUser(projectId) { return isOwner(projectId) || isCollaborator(projectId); }
    function isSigner(projectId, docId) {
      return signedIn()
        && document(projectId, docId).data.signerEmails is list
        && email() in document(projectId, docId).data.signerEmails;
    }

    match /projects/{projectId}/documents/{docId}/{fileName} {
      allow read: if isProjectUser(projectId) || isSigner(projectId, docId);
      allow write: if isProjectUser(projectId)
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*|application/vnd.openxmlformats-officedocument.*|application/msword|text/plain');
    }

    match /projects/{projectId}/artifacts/{docId}/{fileName} {
      allow read: if isProjectUser(projectId) || isSigner(projectId, docId);
      // Los PDFs firmados/certificados se escriben exclusivamente desde Cloud Functions con Admin SDK.
      allow write: if false;
    }

  }
}
