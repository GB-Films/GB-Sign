rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function project(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function isOwnerProjectDoc() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isCollaboratorProjectDoc() {
      return signedIn()
        && resource.data.collaboratorEmails is list
        && userEmail() in resource.data.collaboratorEmails;
    }

    function isProjectUser(projectId) {
      let p = project(projectId);
      return signedIn()
        && (
          p.data.ownerUid == request.auth.uid
          || (
            p.data.collaboratorEmails is list
            && userEmail() in p.data.collaboratorEmails
          )
        );
    }

    function isProjectOwner(projectId) {
      return signedIn()
        && project(projectId).data.ownerUid == request.auth.uid;
    }

    function isDocumentSigner() {
      return signedIn()
        && resource.data.signerEmails is list
        && userEmail() in resource.data.signerEmails;
    }

    function isSignatureRequestSigner() {
      return signedIn()
        && resource.data.signerEmail == userEmail();
    }

    match /admins/{uid} {
      allow get: if signedIn() && uid == request.auth.uid;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && uid == request.auth.uid;
      allow create, update: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == userEmail();
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow create: if isAdmin()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == userEmail()
        && request.resource.data.collaboratorEmails is list;

      allow get, list: if isOwnerProjectDoc() || isCollaboratorProjectDoc();
      allow update: if isProjectOwner(projectId) || isAdmin();
      allow delete: if isProjectOwner(projectId) || isAdmin();

      match /members/{memberId} {
        allow read: if isProjectUser(projectId);
        allow create, update, delete: if isProjectOwner(projectId) || isAdmin();
      }

      match /documents/{docId} {
        allow create: if isProjectUser(projectId)
          && request.resource.data.signerEmails is list;

        allow update, delete: if isProjectUser(projectId);
        allow get, list: if isProjectUser(projectId) || isDocumentSigner();

        match /signatures/{uid} {
          allow get: if isProjectUser(projectId)
            || (signedIn() && uid == request.auth.uid);

          allow list: if isProjectUser(projectId);

          allow create: if signedIn()
            && uid == request.auth.uid
            && userEmail() in get(/databases/$(database)/documents/projects/$(projectId)/documents/$(docId)).data.signerEmails
            && !exists(/databases/$(database)/documents/projects/$(projectId)/documents/$(docId)/signatures/$(uid))
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.email == userEmail()
            && request.resource.data.documentSha256 == get(/databases/$(database)/documents/projects/$(projectId)/documents/$(docId)).data.sha256
            && request.resource.data.consentElectronicSignature == true
            && request.resource.data.dni is string
            && request.resource.data.dni.matches('^[0-9]{6,12}$')
            && request.resource.data.dniConfirmed == true
            && request.resource.data.signatureField.signerEmail == userEmail()
            && request.resource.data.signatureType in ['drawn', 'typed'];

          allow update, delete: if false;
        }
      }
    }

    match /signatureRequests/{requestId} {
      allow create, update: if signedIn()
        && isProjectUser(request.resource.data.projectId)
        && request.resource.data.signerEmail in get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)/documents/$(request.resource.data.docId)).data.signerEmails;

      allow delete: if signedIn()
        && isProjectUser(resource.data.projectId);

      allow get, list: if isSignatureRequestSigner()
        || isProjectUser(resource.data.projectId);
    }
  }
}
